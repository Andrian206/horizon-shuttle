venv/
.venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- OS ---
.DS_Store
Thumbs.db
*.tmp

# --- Logs ---
*.log
logs/

# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- Testing ---
.coverage
htmlcov/
.pytest_cache/
.tox/

# --- Jupyter ---
.ipynb_checkpoints/

